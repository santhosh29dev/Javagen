version: '3.8'

services:
  app:
    build:
      context: ./backend
      dockerfile: ../docker/Dockerfile
    ports:
      - "8080:8080"
    environment:
      - SPRING_PROFILES_ACTIVE=docker
      - DB_HOST=db
    depends_on:
      - db

  db:
    image: {{#database}}postgres:16-alpine{{/database}}{{#database}}mysql:8{{/database}}{{#database}}mongo:7{{/database}}
    environment:
      {{#database}}POSTGRES_DB: {{projectName}}_db
      POSTGRES_USER: root
      POSTGRES_PASSWORD: secret{{/database}}{{#database}}MYSQL_DATABASE: {{projectName}}_db
      MYSQL_ROOT_PASSWORD: secret{{/database}}{{#database}}MONGO_INITDB_DATABASE: {{projectName}}_db{{/database}}
    ports:
      - "{{#database}}5432:5432{{/database}}{{#database}}3306:3306{{/database}}{{#database}}27017:27017{{/database}}"
    volumes:
      - db-data:/var/lib/data

volumes:
  db-data:
